# Frontend (Vite) — set at build time for hosted static deploys
# Use wss:// in production so browser pages served over HTTPS can connect.
VITE_MULTIPLAYER_URL=wss://your-multiplayer-server.example.com

# WebSocket server — set at runtime on your Node host
PORT=8787
# Bind publicly in production (Render/Railway/Fly inject PORT automatically).
HOST=0.0.0.0
# Comma-separated browser origins allowed to open WebSocket connections.
# Leave unset for local development (all origins allowed).
ALLOWED_ORIGINS=https://your-frontend.example.com
